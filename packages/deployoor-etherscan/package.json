{
  "name": "@deployoor/etherscan",
  "version": "0.2.0",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "description": "Verify contracts on Etherscan (V2, all chains) when deployoor deploys them.",
  "keywords": [
    "ethereum",
    "evm",
    "etherscan",
    "verification",
    "deployments",
    "smart-contracts"
  ],
  "license": "MIT",
  "author": "Valerio Leo",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "deployoor": "*",
    "viem": ">=2"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "deployoor": "workspace:*",
    "tsdown": "^0.22.3",
    "typescript": "catalog:",
    "unrun": "^0.3.1",
    "viem": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raycashxyz/deployoor.git",
    "directory": "packages/deployoor-etherscan"
  },
  "homepage": "https://github.com/raycashxyz/deployoor/tree/main/packages/deployoor-etherscan#readme",
  "bugs": {
    "url": "https://github.com/raycashxyz/deployoor/issues"
  }
}
