{
  "name": "deployoor",
  "version": "0.4.0",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "description": "Quality-of-life for smart contract teams — deploy once, use typed viem contract objects in apps and tests.",
  "keywords": [
    "ethereum",
    "evm",
    "viem",
    "deploy",
    "deployment",
    "smart-contracts",
    "hardhat",
    "foundry",
    "wagmi"
  ],
  "license": "MIT",
  "author": "Valerio Leo",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "deployoor": "./dist/cli.mjs"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./plugin": {
      "import": {
        "types": "./dist/plugin-sdk.d.mts",
        "default": "./dist/plugin-sdk.mjs"
      },
      "require": {
        "types": "./dist/plugin-sdk.d.cts",
        "default": "./dist/plugin-sdk.cjs"
      }
    },
    "./generate": {
      "import": {
        "types": "./dist/generate.d.mts",
        "default": "./dist/generate.mjs"
      },
      "require": {
        "types": "./dist/generate.d.cts",
        "default": "./dist/generate.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "typesVersions": {
    "*": {
      "plugin": [
        "./dist/plugin-sdk.d.mts"
      ],
      "generate": [
        "./dist/generate.d.mts"
      ]
    }
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "effect": "catalog:",
    "jiti": "^2.7.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "viem": ">=2",
    "@tevm/compiler": ">=1.0.0-next.148",
    "solc": ">=0.8.0"
  },
  "peerDependenciesMeta": {
    "@tevm/compiler": {
      "optional": true
    },
    "solc": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tevm": "1.0.0-next.149",
    "tsdown": "^0.22.3",
    "typescript": "catalog:",
    "unrun": "^0.3.1",
    "viem": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raycashxyz/deployoor.git",
    "directory": "packages/deployoor"
  },
  "homepage": "https://deployoor.dev",
  "bugs": {
    "url": "https://github.com/raycashxyz/deployoor/issues"
  }
}
