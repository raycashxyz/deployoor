{
  "name": "@example/tevm",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "deployoor on a plain-Solidity project: deployoor generate compiles src/*.sol with tevm (no Hardhat/Foundry) → typed deployers, then deploys on an in-memory EVM.",
  "scripts": {
    "generate": "deployoor generate",
    "deploy": "tsx --env-file-if-exists=.env scripts/deploy.ts",
    "e2e": "deployoor generate && vitest run"
  },
  "dependencies": {
    "deployoor": "workspace:*",
    "viem": "catalog:"
  },
  "devDependencies": {
    "@deployoor/testing": "workspace:*",
    "@tevm/compiler": "1.0.0-next.148",
    "@types/node": "catalog:",
    "solc": "^0.8.26",
    "tsx": "^4.22.4",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
