{
  "name": "@example/hardhat",
  "version": "0.0.0",
  "private": true,
  "description": "deployoor on a Hardhat project: compile → auto-generate typed deployers → deploy, recorded to deployments/. Also tests on an in-memory EVM.",
  "scripts": {
    "generate": "hardhat compile",
    "deploy": "tsx --env-file-if-exists=.env scripts/deploy.ts",
    "e2e": "hardhat compile && vitest run"
  },
  "dependencies": {
    "deployoor": "workspace:*",
    "viem": "catalog:"
  },
  "devDependencies": {
    "@deployoor/hardhat": "workspace:*",
    "@deployoor/testing": "workspace:*",
    "@types/node": "catalog:",
    "hardhat": "^2.22.0",
    "tsx": "^4.22.4",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
